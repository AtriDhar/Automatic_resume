# Market Scout Agent - Environment Variables

# Port (Render sets this automatically)
PORT=8000

# Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# Optional: Custom allowed domains (comma-separated, extends defaults)
# ADDITIONAL_ALLOWED_DOMAINS=customjobboard.com,anotherjobsite.com

# Optional: Cache settings
# CACHE_TTL_SECONDS=3600
# CACHE_MAX_SIZE=100

# Optional: Request timeout (seconds)
# REQUEST_TIMEOUT=25
