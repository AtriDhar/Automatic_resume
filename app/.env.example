# Example environment file.
# Copy to .env.local and replace the value.

# NOTE:
# - In production (Netlify), set GEMINI_API_KEY as a site environment variable.
# - This .env.local is only used for local-dev fallback (and OCR upload fallback).

# Dev-only: set to 'true' if you intentionally want the client bundle to contain the key
# (not recommended for production deployments).
EXPOSE_CLIENT_GEMINI_KEY=false

GEMINI_API_KEY=ADD_YOUR_GEMINI_API_KEY_HERE

# Market Scout Backend URL (Render deployment)
# Local development: http://localhost:8000
# Production: https://your-backend.onrender.com
VITE_BACKEND_URL=http://localhost:8000
